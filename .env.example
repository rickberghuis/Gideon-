# Copy this file to `.env` and fill in your keys. `.env` is git-ignored.

# Required from Tier 1 (the brain)
ANTHROPIC_API_KEY=

# Required from Tier 3 (voice). Leave blank until then.
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Web face password. Required to expose Gideon beyond localhost (--host 0.0.0.0).
# Leave blank for local-only use. Pick something long and random.
GIDEON_WEB_PASSWORD=
